PORT=3000
WS_PORT=3001
NODE_ENV=development

# Database (connects to local docker Postgres)
DATABASE_URL=postgresql://sockpit:sockpit_dev_password@localhost:5432/sockpit

# Redis (connects to local docker Redis)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=supersecretdevkeychangeinproduction12345
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Agent downloads & dashboard
AGENT_DOWNLOAD_BASE_URL=http://localhost:3000/downloads
DASHBOARD_URL=http://localhost:3002

# Encryption Key (32-byte / 64-character hex key)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
