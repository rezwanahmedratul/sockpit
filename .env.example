# SockPit Environment Configuration Template
# Each service uses its own dedicated subdomain.

# Server Core Settings
PORT=3000
WS_PORT=3001
NODE_ENV=production

# Database & Cache Connections
DATABASE_URL=postgresql://sockpit:sockpit_secure_pass@postgres:5432/sockpit?sslmode=disable
POSTGRES_DB=sockpit
POSTGRES_USER=sockpit
POSTGRES_PASSWORD=sockpit_secure_pass
REDIS_URL=redis://redis:6379

# Cryptographic & Authentication Secrets
JWT_SECRET=super_secret_jwt_key_change_in_production_min_16_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# SOCKS5 Password AES-256 Encryption Key (32-byte hex string = 64 hex characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Public Domain URLs (separate subdomain per service)
DASHBOARD_URL=https://panel.yourdomain.com
AGENT_DOWNLOAD_BASE_URL=https://api.yourdomain.com/downloads

# Dashboard Build-time Environment (connects to API and WS via their subdomains)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://ws.yourdomain.com
